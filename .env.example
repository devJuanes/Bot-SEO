NODE_ENV=development
PORT=4100
# En el VPS compartido (growth.matubyte.com) usa PORT=4101 — MatuCash ocupa 4100 y nginx apunta a 4101.
# Admin push WebSocket (MatuSerch): GET /api/admin/push/status · POST /api/admin/push/test
# Socket.IO path /socket.io → events admin:hello / admin:notify

MATUDB_URL=https://db.matudb.com
MATUDB_PROJECT_ID=
MATUDB_API_KEY=
# MATUDB_SERVICE_KEY=

# SaaS auth + encryption for project_secrets (change in production)
AUTH_JWT_SECRET=dev-change-me-auth-jwt-secret
SECRETS_MASTER_KEY=dev-change-me-secrets-master

LLM_PROVIDER=minimax
# MiniMax (OpenAI-compatible) — https://platform.minimax.io/docs/api-reference/text-openai-api
LLM_BASE_URL=https://api.minimax.io/v1
LLM_API_KEY=
LLM_MODEL=MiniMax-M3
# Alternativas: MiniMax-M2.5-highspeed | MiniMax-M2.7

HEADLESS_MODE=true
# En servidor Linux/consola SIEMPRE true (sin ventana). Solo false en PC local para depurar.
WHATSAPP_CTA_URL=

# WhatsApp Cloud API (Meta) — ver docs/CONFIGURACION.md sección WhatsApp
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=matubyte_verify_token
META_APP_ID=
META_APP_SECRET=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_HANDOFF_KEYWORDS=hablar con alguien,agente humano,asesor,hablar con una persona,humano por favor,propuesta,cotización,cotizacion,quiero cotizar,hablar con un asesor,me interesa la propuesta
# Tu WhatsApp personal (código país + número, sin + ni espacios). Ahí te llegan los avisos de handoff.
WHATSAPP_OWNER_PHONE=573332771764

# Autopilot: al arrancar empieza a cazar solo (rota ciudad/sector CO+LatAm)
AUTO_START_AGENTS=true
AUTO_START_DELAY_MS=8000
AUTO_HUNT_INTERVAL_MS=900000

LEAD_HUNTER_CITY=Cali
LEAD_HUNTER_SECTOR=
LEAD_HUNTER_QUERY=
LEAD_HUNTER_MAX_RESULTS=12

CRON_LEAD_HUNTER=0 */6 * * *
CRON_OPPORTUNITY_SCOUT=30 */6 * * *
CRON_INFILTRATOR=0 */4 * * *
CRON_CONTENT_RADAR=0 7 * * *
CRON_CATALOG_CURATOR=0 6 * * *
CRON_EDITORIAL_PLANNER=30 6 * * *
CRON_BLOG_WRITER=0 8 * * *
CRON_SOCIAL_CREATOR=0 9 * * *
CRON_COMMUNITY_AGENT=0 */3 * * *
CRON_FACEBOOK_PUBLISHER=0 10,16,22 * * *

# Facebook Pages API (Meta Graph) — agente facebook-publisher
# Documentación: https://developers.facebook.com/docs/pages-api
# FB_DRY_RUN=true evita publicaciones accidentales en dev.
# Para publicar de verdad: FB_DRY_RUN=false con page access token válido.
FB_PUBLISHER_ENABLED=false
FB_DRY_RUN=true
# false = cola de aprobación en http://localhost:4100/facebook.html
# true  = publica solo (sigue respetando FB_DRY_RUN)
FB_AUTO_PUBLISH=false
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
FB_GRAPH_VERSION=v21.0

# Opcional: fotos reales según el tema del post (https://www.pexels.com/api/)
# Sin esto usa catálogo local rotativo por keyword del copy.
PEXELS_API_KEY=

# Facebook Webhooks — recibir comentarios, reactions, feed, leads, messenger.
# Requiere URL HTTPS pública (en dev: ngrok http 4100 → https://xxxx.ngrok-free.app)
# Eventos disponibles: feed, comments, reactions, leadgen, messaging
FB_WEBHOOK_ENABLED=false
FB_WEBHOOK_VERIFY_TOKEN=matubyte_fb_verify_token
