NODE_ENV=development
PORT=4100

MATUDB_URL=https://db.matudb.com
MATUDB_PROJECT_ID=
MATUDB_API_KEY=
# MATUDB_SERVICE_KEY=

LLM_PROVIDER=api
# MiniMax (OpenAI-compatible) — https://platform.minimax.io/docs/api-reference/text-openai-api
LLM_BASE_URL=https://api.minimax.io/v1
LLM_API_KEY=
LLM_MODEL=MiniMax-M3
# Alternativas: MiniMax-M2.5-highspeed | MiniMax-M2.7

HEADLESS_MODE=true
# En servidor Linux/consola SIEMPRE true (sin ventana). Solo false en PC local para depurar.
WHATSAPP_CTA_URL=

# WhatsApp Cloud API (Meta) — ver docs/CONFIGURACION.md sección WhatsApp
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=matubyte_verify_token
META_APP_SECRET=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_HANDOFF_KEYWORDS=hablar con alguien,agente humano,asesor,hablar con una persona,humano por favor

# Autopilot: al arrancar empieza a cazar solo (rota ciudad/sector CO+LatAm)
AUTO_START_AGENTS=true
AUTO_START_DELAY_MS=8000
AUTO_HUNT_INTERVAL_MS=900000

LEAD_HUNTER_CITY=Cali
LEAD_HUNTER_SECTOR=
LEAD_HUNTER_QUERY=
LEAD_HUNTER_MAX_RESULTS=12

CRON_LEAD_HUNTER=0 */6 * * *
CRON_OPPORTUNITY_SCOUT=30 */6 * * *
CRON_INFILTRATOR=0 */4 * * *
CRON_CONTENT_RADAR=0 7 * * *
CRON_BLOG_WRITER=0 8 * * *
CRON_SOCIAL_CREATOR=0 9 * * *
CRON_COMMUNITY_AGENT=0 */3 * * *
