{
  "name": "matubyte-growth-factory",
  "version": "1.0.0",
  "description": "Fábrica de Growth — agentes autónomos de prospección, SEO y leads para MatuByte S.A.S.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently -k -n api,ui -c blue,magenta \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "tsx watch --clear-screen=false --include .env src/index.ts",
    "dev:ui": "vite --config frontend/vite.config.ts",
    "build": "tsc -p tsconfig.json",
    "build:ui": "vite build --config frontend/vite.config.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p frontend/tsconfig.json --noEmit",
    "migrate": "tsx scripts/migrate.ts",
    "export:tenant": "tsx scripts/export-tenant-data.ts",
    "import:tenant": "tsx scripts/import-tenant-data.ts",
    "smoke:phase2": "tsx scripts/smoke-phase2.ts",
    "smoke:facebook": "tsx scripts/smoke-facebook-publisher.ts",
    "smoke:llm": "tsx scripts/smoke-llm.ts",
    "playwright:install": "playwright install chromium",
    "smoke:playwright": "tsx scripts/smoke-playwright.ts"
  },
  "dependencies": {
    "@devjuanes/matuclient": "^2.2.3",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^10.1.0",
    "@xenova/transformers": "^2.17.2",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "lucide-react": "^1.25.0",
    "node-cron": "^3.0.3",
    "playwright": "^1.50.1",
    "recharts": "^3.10.0",
    "socket.io": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.4.0",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  }
}
